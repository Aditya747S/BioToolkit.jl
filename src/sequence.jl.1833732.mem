        -         amino_acid = (code1 > 3 || code2 > 3 || code3 > 3) ? UInt8('X') : codon_table[((Int(code1) << 4) | (Int(code2) << 2) | Int(code3)) + 1]
        -         if stop_at_stop && amino_acid == UInt8('*')
