        - function kmer_frequency(bytes::AbstractVector{UInt8}, k::Integer)
        -     if _is_cuda_backed_array(bytes)
        -         _ensure_cuda_sequence!()
        -         return Base.invokelatest(_CUDA_SEQUENCE_KMER_IMPL[], bytes, k)
        -     end
        - 
        -     return kmer_frequency(String(bytes), k)
