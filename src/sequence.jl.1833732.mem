        - function score_grna_efficiency(guide::AbstractString; pam::AbstractString="NGG")
        -     sequence = uppercase(strip(String(guide)))
        -     isempty(sequence) && return 0.0
        - 
        -     gc = gc_content(sequence)
        -     gc_score = clamp(1.0 - abs(gc - 0.5) / 0.5, 0.0, 1.0)
        -     poly_penalty = occursin(r"A{4,}|C{4,}|G{4,}|T{4,}", sequence) ? 0.25 : 0.0
        -     seed_bonus = startswith(sequence, "G") ? 0.05 : 0.0
        -     pam_bonus = endswith(uppercase(String(pam)), "GG") ? (endswith(sequence, "G") ? 0.05 : 0.0) : 0.0
        - 
        -     score = 0.6 * gc_score + seed_bonus + pam_bonus - poly_penalty
        -     return clamp(score, 0.0, 1.0)
        - end
        - 
        - # ─── GC Skew ──────────────────────────────────────────────────────────────────
        - 
        - """
        -     gc_skew(sequence)
        - 
        - Compute cumulative GC skew values. At each position, +1 for G, -1 for C.
        - Returns a Vector{Int} of length equal to the sequence.
        - """
        - function gc_skew(sequence::AbstractString)
        -     bytes = codeunits(sequence)
        -     len = length(bytes)
        -     skew_values = Vector{Int}(undef, len)
        -     current = 0
        - 
        -     @inbounds for i in 1:len
        -         ch = bytes[i] | 0x20  # lowercase
        -         current += (ch == UInt8('g')) - (ch == UInt8('c'))
        -         skew_values[i] = current
        -     end
        - 
        -     return skew_values
        - end
        - 
        - function gc_skew(bytes::AbstractVector{UInt8})
        -     len = length(bytes)
        -     skew_values = Vector{Int}(undef, len)
        -     current = 0
        - 
        -     @inbounds for i in 1:len
        -         ch = bytes[i] | 0x20
        -         current += (ch == UInt8('g')) - (ch == UInt8('c'))
        -         skew_values[i] = current
        -     end
        - 
        -     return skew_values
        - end
        - 
        - """
        -     minimum_skew(sequence)
        - 
        - Find genome positions where the GC skew is minimum (potential replication origins).
        - Returns a Vector{Int} of 1-based positions.
        - """
        - function minimum_skew(sequence)
        -     skew_values = gc_skew(sequence)
        -     isempty(skew_values) && return Int[]
        -     min_val = minimum(skew_values)
        -     return findall(==(min_val), skew_values)
        - end
        - 
        - # ─── Dotmatrix ────────────────────────────────────────────────────────────────
        - 
        - """
        -     dotmatrix(seq1, seq2)
        - 
        - Compute a dot-plot matrix comparing two sequences.
        - Returns a Matrix{Int8} where 1 = match, 0 = mismatch.
        - Rows correspond to seq1, columns to seq2.
        - """
        - function dotmatrix(seq1::AbstractString, seq2::AbstractString)
        -     return dotmatrix(codeunits(seq1), codeunits(seq2))
        - end
        - 
        - function dotmatrix(seq1::AbstractVector{UInt8}, seq2::AbstractVector{UInt8})
        -     if _is_cuda_backed_array(seq1) && _is_cuda_backed_array(seq2)
        -         _ensure_cuda_sequence!()
        -         return Base.invokelatest(_CUDA_SEQUENCE_DOTMATRIX_IMPL[], seq1, seq2)
        -     end
        - 
        -     m = length(seq1)
        -     n = length(seq2)
        -     matrix = Matrix{Int8}(undef, m, n)
        - 
        -     @inbounds for j in 1:n
        -         b2 = seq2[j] | 0x20  # case-insensitive
        -         for i in 1:m
        -             matrix[i, j] = Int8((seq1[i] | 0x20) == b2)
        -         end
        -     end
        - 
        -     return matrix
        - end
