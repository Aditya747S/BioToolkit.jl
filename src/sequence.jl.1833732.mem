        - function find_orfs(sequence::AbstractString; min_aa::Integer=0)
        -     upper = uppercase(sequence)
        -     bytes = codeunits(upper)
        -     proteins = String[]
        - 
        -     for frame in 1:3
        -         protein = translate_dna(bytes[frame:end]; stop_at_stop=false)
        -         if length(protein) >= min_aa
        -             push!(proteins, protein)
        -         end
        - 
        -         reverse_protein = translate_dna(reverse_complement(bytes[frame:end]); stop_at_stop=false)
        -         if length(reverse_protein) >= min_aa
        -             push!(proteins, reverse_protein)
        -         end
        -     end
        - 
        -     return proteins
        - end
