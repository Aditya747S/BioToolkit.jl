        -     @inbounds while index + 2 <= last
        -         code1 = code_table[Int(bytes[index]) + 1]
        -         code2 = code_table[Int(bytes[index + 1]) + 1]
        -         code3 = code_table[Int(bytes[index + 2]) + 1]
